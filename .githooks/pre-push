#!/bin/bash
# TradeJob Pro — Pre-Push Hook
# Se ejecuta antes de cada push. Si falla, el push se rechaza.

echo "🔍 Pre-push hook: Verificando build y tests..."

ROOT_DIR=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$ROOT_DIR" ]; then
    echo "❌ No se pudo determinar la raíz del repo"
    exit 1
fi

cd "$ROOT_DIR" || exit 1

# Verificar que gradlew existe
if [ ! -f "./gradlew" ]; then
    echo "❌ gradlew no encontrado en $ROOT_DIR"
    exit 1
fi

chmod +x gradlew

# 1. Compilación
echo "⏳ Compilando (assembleDebug)..."
./gradlew assembleDebug --quiet --daemon 2>/dev/null
if [ $? -ne 0 ]; then
    echo "❌ ERROR DE COMPILACIÓN: El push ha sido RECHAZADO."
    echo "   Corre 'make fix' o arregla los errores e intenta de nuevo."
    exit 1
fi
echo "✅ Compilación OK"

# 2. Tests unitarios
echo "⏳ Ejecutando tests unitarios..."
./gradlew test --quiet --daemon 2>/dev/null
if [ $? -ne 0 ]; then
    echo "❌ TESTS FALLIDOS: El push ha sido RECHAZADO."
    echo "   Revisa los tests y vuelve a intentarlo."
    exit 1
fi
echo "✅ Tests OK"

echo "✅ Pre-push hook superado. Subiendo cambios..."
exit 0
